---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = Astro.url;
const sourceFilter = url.searchParams.get('source') || '';
const dateFilter = url.searchParams.get('date') || '';

const sources = [...new Set(articles.map(a => a.data.source))].sort();
const dates = [...new Set(articles.map(a => a.data.date.slice(0, 10)))].sort().reverse();

const filtered = articles.filter(a => {
  if (sourceFilter && a.data.source !== sourceFilter) return false;
  if (dateFilter && !a.data.date.startsWith(dateFilter)) return false;
  return true;
});

function tagClass(source: string) {
  const map: Record<string, string> = { HN: 'tag-hn', Reddit: 'tag-reddit', GitHub: 'tag-github', PH: 'tag-ph' };
  return map[source] || '';
}
---
<Base title="Deep Dive Daily">
  <div class="filters">
    <a href="/" class:list={[{ active: !sourceFilter && !dateFilter }]}>全部</a>
    {sources.map(s => (
      <a href={`/?source=${s}`} class:list={[{ active: sourceFilter === s }]}>{s}</a>
    ))}
  </div>
  <div class="filters">
    {dates.map(d => (
      <a href={dateFilter === d ? '/' : `/?date=${d}`} class:list={[{ active: dateFilter === d }]}>{d}</a>
    ))}
  </div>
  {filtered.map(article => (
    <div class="article-card">
      <div class="article-meta">
        <span class={`tag ${tagClass(article.data.source)}`}>{article.data.source}</span>
        <span>{article.data.date}</span>
      </div>
      <h2><a href={`/articles/${article.data.slug}`}>{article.data.title}</a></h2>
      {article.data.summary && <p class="article-summary">{article.data.summary}</p>}
    </div>
  ))}
  {filtered.length === 0 && <p style="color:var(--muted);margin-top:2rem;">暂无文章</p>}
</Base>
